---
---

<section id="quick-start" class="py-20 sm:py-32 bg-gray-50 dark:bg-gray-900">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center mb-16">
      <h2 class="text-3xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-4xl">
        Quick Start
      </h2>
      <p class="mt-4 text-lg text-gray-600 dark:text-gray-300">
        Get up and running in minutes
      </p>
    </div>

    <!-- Tabs -->
    <div class="mx-auto max-w-4xl">
      <div class="border-b border-gray-200 dark:border-gray-800">
        <nav class="-mb-px flex space-x-8" aria-label="Tabs">
          <button
            class="tab-button border-b-2 border-blue-600 py-4 px-1 text-sm font-medium text-blue-600"
            data-tab="one-line"
          >
            One-line Install
          </button>
          <button
            class="tab-button border-b-2 border-transparent py-4 px-1 text-sm font-medium text-gray-500 hover:border-gray-300 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-300"
            data-tab="local-dev"
          >
            Local Development
          </button>
          <button
            class="tab-button border-b-2 border-transparent py-4 px-1 text-sm font-medium text-gray-500 hover:border-gray-300 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-300"
            data-tab="docker"
          >
            Docker Compose
          </button>
        </nav>
      </div>

      <!-- Tab Content -->
      <div class="mt-8">
        <div class="tab-content" id="one-line">
          <div class="rounded-lg bg-gray-900 p-6">
            <pre class="text-sm text-gray-100 overflow-x-auto"><code>curl -fsSL https://raw.githubusercontent.com/thambaru/vps-snapshot-manager/main/scripts/deploy.sh | bash</code></pre>
          </div>
          <p class="mt-4 text-gray-600 dark:text-gray-400">
            The script installs Docker and Git if missing, clones the repo, generates a secret key, and starts the stack. Open <a href="http://localhost" class="text-blue-600 hover:underline">http://localhost</a> when it finishes.
          </p>
        </div>

        <div class="tab-content hidden" id="local-dev">
          <div class="rounded-lg bg-gray-900 p-6">
            <pre class="text-sm text-gray-100 overflow-x-auto"><code>./scripts/setup.sh
pnpm dev</code></pre>
          </div>
          <p class="mt-4 text-gray-600 dark:text-gray-400">
            <strong>Prerequisites:</strong> Node.js 20+, pnpm, rclone<br>
            API: <a href="http://localhost:3001" class="text-blue-600 hover:underline">http://localhost:3001</a><br>
            Web: <a href="http://localhost:3000" class="text-blue-600 hover:underline">http://localhost:3000</a>
          </p>
        </div>

        <div class="tab-content hidden" id="docker">
          <div class="rounded-lg bg-gray-900 p-6">
            <pre class="text-sm text-gray-100 overflow-x-auto"><code>git clone https://github.com/thambaru/vps-snapshot-manager
cd vps-snapshot-manager
echo "APP_SECRET=$(openssl rand -hex 32)" > .env
docker-compose up -d</code></pre>
          </div>
          <p class="mt-4 text-gray-600 dark:text-gray-400">
            Open <a href="http://localhost" class="text-blue-600 hover:underline">http://localhost</a> in your browser.
          </p>
        </div>
      </div>

      <!-- Environment Variables Table -->
      <div class="mt-12">
        <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-4">Configuration</h3>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-800">
            <thead class="bg-gray-50 dark:bg-gray-800">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Variable</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Description</th>
              </tr>
            </thead>
            <tbody class="bg-white dark:bg-gray-900 divide-y divide-gray-200 dark:divide-gray-800">
              <tr>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-mono text-gray-900 dark:text-white">APP_SECRET</td>
                <td class="px-6 py-4 text-sm text-gray-600 dark:text-gray-400">64-character hex string (run <code class="bg-gray-100 dark:bg-gray-800 px-1 rounded">openssl rand -hex 32</code>)</td>
              </tr>
              <tr>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-mono text-gray-900 dark:text-white">PORT</td>
                <td class="px-6 py-4 text-sm text-gray-600 dark:text-gray-400">API server port (default: 3001)</td>
              </tr>
              <tr>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-mono text-gray-900 dark:text-white">DATABASE_PATH</td>
                <td class="px-6 py-4 text-sm text-gray-600 dark:text-gray-400">SQLite database path (default: ./data/snapshots.db)</td>
              </tr>
              <tr>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-mono text-gray-900 dark:text-white">TEMP_DIR</td>
                <td class="px-6 py-4 text-sm text-gray-600 dark:text-gray-400">Temporary staging directory (default: ./tmp)</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <p class="mt-8 text-center text-gray-600 dark:text-gray-400">
        For detailed documentation, see the <a href="https://github.com/thambaru/vps-snapshot-manager#readme" class="text-blue-600 hover:underline" target="_blank" rel="noopener noreferrer">full README</a>
      </p>
    </div>
  </div>
</section>

<script>
  const tabButtons = document.querySelectorAll('.tab-button');
  const tabContents = document.querySelectorAll('.tab-content');

  tabButtons.forEach((button) => {
    button.addEventListener('click', () => {
      const tabName = button.getAttribute('data-tab');
      
      // Update buttons
      tabButtons.forEach((btn) => {
        btn.classList.remove('border-blue-600', 'text-blue-600');
        btn.classList.add('border-transparent', 'text-gray-500', 'dark:text-gray-400');
      });
      button.classList.remove('border-transparent', 'text-gray-500', 'dark:text-gray-400');
      button.classList.add('border-blue-600', 'text-blue-600');
      
      // Update content
      tabContents.forEach((content) => {
        if (content.id === tabName) {
          content.classList.remove('hidden');
        } else {
          content.classList.add('hidden');
        }
      });
    });
  });
</script>
