---
---

<section class="relative overflow-hidden bg-gradient-to-b from-blue-50 to-white dark:from-gray-900 dark:to-gray-950 py-20 sm:py-32">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h1 class="text-4xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-6xl">
        VPS Snapshot Manager
      </h1>
      <p class="mt-6 text-lg leading-8 text-gray-600 dark:text-gray-300">
        Self-hosted VPS snapshot manager with 70+ cloud storage providers
      </p>
      
      <!-- Install command -->
      <div class="mt-10 flex flex-col items-center gap-4">
        <div class="w-full max-w-2xl">
          <div class="relative rounded-lg bg-gray-900 p-6 shadow-2xl">
            <div class="flex items-center justify-between mb-3">
              <div class="flex gap-1.5">
                <div class="w-3 h-3 rounded-full bg-red-500"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                <div class="w-3 h-3 rounded-full bg-green-500"></div>
              </div>
              <button 
                id="copy-button"
                class="text-xs text-gray-400 hover:text-white transition-colors px-3 py-1 rounded bg-gray-800 hover:bg-gray-700"
                aria-label="Copy install command"
              >
                Copy
              </button>
            </div>
            <code class="text-sm text-green-400 font-mono block overflow-x-auto" id="install-command">
              curl -fsSL https://raw.githubusercontent.com/thambaru/vps-snapshot-manager/main/scripts/deploy.sh | bash
            </code>
          </div>
        </div>
        
        <!-- CTA Buttons -->
        <div class="flex flex-wrap items-center justify-center gap-4">
          <a 
            href="#quick-start" 
            class="rounded-md bg-blue-600 px-6 py-3 text-sm font-semibold text-white shadow-sm hover:bg-blue-500 transition-colors"
          >
            Get Started
          </a>
          <a 
            href="https://github.com/thambaru/vps-snapshot-manager" 
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-md bg-gray-800 dark:bg-gray-700 px-6 py-3 text-sm font-semibold text-white shadow-sm hover:bg-gray-700 dark:hover:bg-gray-600 transition-colors"
          >
            GitHub →
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const copyButton = document.getElementById('copy-button');
  const installCommand = document.getElementById('install-command');
  
  if (copyButton && installCommand) {
    copyButton.addEventListener('click', async () => {
      const text = installCommand.textContent?.trim() || '';
      await navigator.clipboard.writeText(text);
      copyButton.textContent = 'Copied!';
      setTimeout(() => {
        copyButton.textContent = 'Copy';
      }, 2000);
    });
  }
</script>
