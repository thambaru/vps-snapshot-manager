{
  "name": "@vps-snapshot/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --dts --out-dir dist --external node-forge",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "fastify": "^5.2.1",
    "@fastify/websocket": "^11.0.2",
    "@fastify/cors": "^10.0.2",
    "@fastify/static": "^8.1.1",
    "drizzle-orm": "^0.40.0",
    "better-sqlite3": "^11.8.1",
    "node-ssh": "^13.2.0",
    "node-cron": "^3.0.3",
    "zod": "^3.24.1",
    "dotenv": "^16.4.7",
    "node-forge": "^1.3.1",
    "uuid": "^11.0.5",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "drizzle-kit": "^0.30.4",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.4",
    "@types/node-forge": "^1.3.11",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.2",
    "tsup": "^8.3.6"
  }
}
